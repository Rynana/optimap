# Default: normalise line endings to LF in the index
* text=auto eol=lf

# Shell scripts always LF
*.sh text eol=lf

# Windows-specific scripts stay CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Source files — explicit LF
*.ts   text eol=lf
*.tsx  text eol=lf
*.js   text eol=lf
*.jsx  text eol=lf
*.mjs  text eol=lf
*.cjs  text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml  text eol=lf
*.toml text eol=lf
*.css  text eol=lf
*.html text eol=lf
*.md   text eol=lf
*.rs   text eol=lf

# Binary — do not touch
*.png  binary
*.jpg  binary
*.jpeg binary
*.ico  binary
*.icns binary
*.wasm binary
*.pdf  binary
